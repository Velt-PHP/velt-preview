{
    "name": "velt/preview",
    "description": "Module Preview pour VeltPHP - Prévisualisation mobile via QR code",
    "type": "library",
    "autoload": {
        "psr-4": {
            "PreviewContracts\\": "preview-contracts/src/",
            "PreviewSessionStore\\": "preview-session-store/src/",
            "PreviewEndpoints\\": "preview-endpoints/src/",
            "PreviewQrCli\\": "preview-qr-cli/src/",
            "VeltAst\\": "velt-ast/src/",
            "VeltParser\\": "velt-parser/src/",
            "VeltView\\": "velt-view/src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "bacon/bacon-qr-code": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "bin": [
        "preview-qr-cli/bin/velt"
    ]
}
