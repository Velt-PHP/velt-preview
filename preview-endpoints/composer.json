{
    "name": "velt/preview-endpoints",
    "description": "HTTP endpoints for Velt preview responses",
    "autoload": {
        "psr-4": {
            "PreviewEndpoints\\": "src/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../preview-session-store",
            "options": {
