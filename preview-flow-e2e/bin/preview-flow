#!/usr/bin/env php
<?php

require_once dirname(__DIR__, 2) . '/preview-session-store/src/PreviewSession.php';
require_once dirname(__DIR__, 2) . '/preview-session-store/src/Exceptions/PreviewSessionNotFoundException.php';
require_once dirname(__DIR__, 2) . '/preview-session-store/src/PreviewSessionStore.php';
require_once dirname(__DIR__, 2) . '/preview-contracts/src/PreviewPage.php';
require_once dirname(__DIR__, 2) . '/preview-contracts/src/Contracts/JsonRendererInterface.php';
require_once dirname(__DIR__, 2) . '/preview-contracts/src/Contracts/PageRepositoryInterface.php';
require_once dirname(__DIR__, 2) . '/preview-contracts/src/Contract/PreviewSchema.php';
require_once dirname(__DIR__, 2) . '/preview-endpoints/src/Http/Response.php';
require_once dirname(__DIR__, 2) . '/preview-endpoints/src/Http/PreviewErrorResponse.php';
require_once dirname(__DIR__, 2) . '/preview-endpoints/src/Renderer/ArrayJsonRenderer.php';
require_once dirname(__DIR__, 2) . '/preview-endpoints/src/Repository/ArrayPageRepository.php';
require_once dirname(__DIR__, 2) . '/preview-endpoints/src/Http/PreviewController.php';
require __DIR__ . '/../vendor/autoload.php';

use PreviewFlowE2E\PreviewFlowRunner;

$storageDir = __DIR__ . '/../storage';
$runner = new PreviewFlowRunner($storageDir);
$report = $runner->run();

echo "Preview flow report\n";
echo "===================\n";
echo "Happy path status: " . $report['happyPath']['status'] . "\n";
echo "Has screen: " . ($report['happyPath']['hasScreen'] ? 'yes' : 'no') . "\n";
echo "Has schemaVersion: " . ($report['happyPath']['hasSchemaVersion'] ? 'yes' : 'no') . "\n";
echo "Has components: " . ($report['happyPath']['hasComponents'] ? 'yes' : 'no') . "\n";
echo "Missing session status: " . $report['missingSession']['status'] . "\n";
echo "Missing page status: " . $report['missingPage']['status'] . "\n\n";

echo "Sample payload (happy path):\n";
echo json_encode($report['happyPath']['payload'], JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . "\n";
